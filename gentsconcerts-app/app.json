{
  "expo": {
    "name": "GentsConcerts",
    "slug": "gentsconcerts-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.gentsconcerts.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#001F5B"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    }
  }
}
